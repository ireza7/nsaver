{
  "name": "nsaver",
  "version": "3.0.0",
  "description": "nhentai gallery downloader Telegram bot with nZip-style ZIP generation, channel caching, and concurrent image downloads",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nhentai",
    "telegram",
    "bot",
    "favorites",
    "zip",
    "nzip",
    "download"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.0",
    "mysql2": "^3.12.0",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.12.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
