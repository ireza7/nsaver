{
  "name": "nsaver",
  "version": "2.1.0",
  "description": "nhentai favorites exporter Telegram bot with PDF generation, channel caching, and nZip integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["nhentai", "telegram", "bot", "favorites", "pdf", "nzip"],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.0",
    "mysql2": "^3.12.0",
    "node-telegram-bot-api": "^0.66.0",
    "pdfkit": "^0.15.1",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/pdfkit": "^0.13.8",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
