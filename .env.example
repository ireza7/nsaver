# -------------------------------------------------------
# Telegram bot config (required)
# -------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Private channel ID where PDFs are cached (bot must be admin)
TELEGRAM_CHANNEL_ID=-1001234567890

# Comma-separated list of Telegram user IDs allowed to use the bot (empty = all)
# ADMIN_USER_IDS=123456,789012

# -------------------------------------------------------
# External MySQL database config (required)
# Use a remote MySQL service to reduce server load
# -------------------------------------------------------
MYSQL_HOST=your-mysql-host.com
MYSQL_PORT=3306
MYSQL_USER=nsaver
MYSQL_PASSWORD=your_secure_password
MYSQL_DATABASE=nsaver

# -------------------------------------------------------
# Scraping settings
# -------------------------------------------------------
# Maximum number of favorites pages to scrape per user (0 = all pages)
# MAX_PAGES=0

# Delay between requests in seconds (default: 2)
# REQUEST_DELAY=2

# Maximum galleries per PDF export (default: 50)
# MAX_GALLERIES_PER_PDF=50

# Default User-Agent (optional, has sensible default)
# NHENTAI_USER_AGENT=Mozilla/5.0 ...
